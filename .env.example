# MongoDB Configuration
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin

# Application Configuration
APP_PORT=5000

# MongoDB Connection URL
# For Docker containers (use service name 'mongodb'):
MONGODB_URL=mongodb://admin:admin@mongodb:27017/axora_search?authSource=admin
# For host machine (use 'localhost'):
# MONGODB_URL=mongodb://admin:admin@localhost:27017/axora_search?authSource=admin